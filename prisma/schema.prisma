  empresas          empresas  @relation(fields: [id_empresa], references: [id_empresa], onDelete: NoAction, onUpdate: NoAction)
  puestos           puestos   @relation(fields: [id_puesto], references: [id_puesto], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_cliente], map: "idx_clientes_puestos_cliente")
  @@index([id_puesto], map: "idx_clientes_puestos_puesto")
}

