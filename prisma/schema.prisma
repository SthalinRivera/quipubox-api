generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model calidades {
  id_calidad              BigInt                    @id @default(autoincrement())
  id_empresa              BigInt
  nombre                  String
  descripcion             String?
  estado                  Boolean?                  @default(true)
  created_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  empresas                empresas                  @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade, onUpdate: NoAction)
  detalle_carga_calidades detalle_carga_calidades[]

  @@unique([id_empresa, nombre], map: "uq_calidad_empresa")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model camiones {
  id_camion         BigInt              @id @default(autoincrement())
  id_empresa        BigInt
  placa             String
  observaciones     String?
  estado            Boolean?            @default(true)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  descripcion       String?
  empresas          empresas            @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade, onUpdate: NoAction)
  operaciones_carga operaciones_carga[]

  @@unique([id_empresa, placa], map: "uq_camion_empresa_placa")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model cliente_sede {
  id_cliente_sede BigInt    @id @default(autoincrement())
  id_empresa      BigInt
  id_cliente      BigInt
  id_sede         BigInt
  observaciones   String?
  estado          Boolean?  @default(true)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  tipo_relacion   String
  clientes        clientes  @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, onUpdate: NoAction)
  empresas        empresas  @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade, onUpdate: NoAction)
  sedes           sedes     @relation(fields: [id_sede], references: [id_sede], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_cliente], map: "idx_cliente_sede_cliente")
  @@index([id_sede], map: "idx_cliente_sede_sede")
  @@index([tipo_relacion], map: "idx_cliente_sede_tipo_relacion")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model clientes {
  id_cliente       BigInt             @id @default(autoincrement())
  id_empresa       BigInt
  nombres          String
  apellidos        String?
  apodo            String?
  telefono         String?            @unique
  observaciones    String?
  estado           Boolean            @default(true)
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  cliente_sede     cliente_sede[]
  empresas         empresas           @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade, onUpdate: NoAction)
  clientes_puestos clientes_puestos[]
  detalle_carga    detalle_carga[]
  entregas         entregas[]
  guias_operativas guias_operativas[]
  items_reparto    items_reparto[]
  jabas_por_cobrar jabas_por_cobrar[]
  jabas_por_pagar  jabas_por_pagar[]

  @@unique([id_empresa, nombres], map: "uq_cliente_empresa_nombre")
  @@index([id_empresa, nombres], map: "idx_clientes_empresa_nombre")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model clientes_puestos {
  id_cliente_puesto BigInt    @id @default(autoincrement())
